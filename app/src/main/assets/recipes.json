    {
        "id":  "garlic-butter-chicken",
        "name":  "Garlic Butter Chicken",
        "summary":  "Golden chicken breast finished in a bright lemon-garlic pan sauce.",
        "cuisine":  "American",
        "tags":  [
                     "High Protein",
                     "Gluten Free"
                 ],
        "prepMinutes":  10,
        "cookMinutes":  18,
        "servings":  2,
        "ingredients":  [
                            {
                                "name":  "Chicken Breast",
                                "amount":  "2 pieces",
                                "category":  "Protein"
                            },
                            {
                                "name":  "Butter",
                                "amount":  "3 tbsp",
                                "category":  "Dairy"
                            },
                            {
                                "name":  "Garlic",
                                "amount":  "4 cloves",
                                "category":  "Produce"
                            },
                            {
                                "name":  "Lemon",
                                "amount":  "1",
                                "category":  "Produce"
                            },
                            {
                                "name":  "Olive Oil",
                                "amount":  "1 tbsp",
                                "category":  "Pantry"
                            },
                            {
                                "name":  "Salt \u0026 Pepper",
                                "amount":  "to taste",
                                "category":  "Spices"
                            }
                        ],
        "steps":  [
                      "Pat the chicken dry and season both sides with salt and pepper.",
                      "Heat olive oil and one tablespoon of butter in a skillet over medium-high heat.",
                      "Cook the chicken until golden and cooked through, about 6 to 7 minutes per side.",
                      "Lower the heat, add the remaining butter and minced garlic, and cook for 30 seconds.",
                      "Squeeze in the lemon juice and spoon the pan sauce over the chicken."
                  ],
